# PVE VM Forge configuration

# Common values: local-lvm, local-zfs, local, ceph-vm
PVE_STORAGE="local-lvm"

# Proxmox bridge used by VMs.
PVE_BRIDGE="vmbr0"

# Storage used for cloud-init snippets.
# Usually "local" maps to /var/lib/vz.
SNIPPET_STORAGE="local"
SNIPPET_DIR="/var/lib/vz/snippets"

# Directory used to cache downloaded cloud images.
IMAGE_DIR="/var/lib/vz/template/pve-vm-forge"

# Default clone mode.
# 0 = linked clone, fastest and smallest
# 1 = full clone, more independent but slower
DEFAULT_FULL_CLONE="0"

# Image versions / channels.
# Ubuntu 26.04 LTS current cloud image channel in 2026.
# You may switch to "noble" for Ubuntu 24.04 LTS if preferred.
UBUNTU_SERIES="resolute"

# Debian stable in 2026.
DEBIAN_SERIES="trixie"
DEBIAN_VERSION="13"

# Template VMIDs. Keep them in the 9000 range to avoid collisions.
TPL_UBUNTU_SERVER="9000"
TPL_DEBIAN_SERVER="9001"
TPL_KALI_CLOUD="9002"

# Optional default DNS injected by cloud-init. Leave empty to use DHCP DNS.
DEFAULT_NAMESERVER=""
DEFAULT_SEARCHDOMAIN=""
